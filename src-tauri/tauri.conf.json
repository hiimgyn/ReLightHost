{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReLightHost",
  "version": "0.1.0",
  "identifier": "com.gyn.relighthost",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "ReLightHost",
        "width": 950,
        "height": 450,
        "minWidth": 800,
        "minHeight": 450,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
