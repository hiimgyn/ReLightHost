{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReLightHost",
  "version": "1.4.5",
  "identifier": "com.HiimGyn.relighthost",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "ReLightHost",
        "width": 1200,
        "height": 850,
        "minWidth": 1200,
        "minHeight": 850,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "startMenuFolder": "ReLightHost"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {}
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBMTZGOTlGMzM5NTNCQTEKUldTaE81VXpuL2tXdXQvc1lURFNSc3dQNExJZVVTUjk3cW9SUVBiNUxiSGFIUmJuSjN0M2xGU2EK",
      "endpoints": [
        "https://github.com/HiimGyn/ReLightHost/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
